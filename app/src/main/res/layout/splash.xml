<?xml version="1.0" encoding="utf-8"?>
<!--
    PANTALLA DE CARGA
    Ajustes visuales: Logo reducido, título más cercano al logo y créditos a la derecha.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:orientation="vertical"
    tools:context=".Splash">


    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.7" />


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <!-- Logo -->
        <ImageView
            android:id="@+id/LogoApp"
            android:layout_width="@dimen/logo_splash_width"
            android:layout_height="@dimen/logo_splash_height"
            android:contentDescription="@string/desc_logo_app"
            android:src="@drawable/logo" />

        <!-- Título -->
        <TextView
            android:id="@+id/Nombreapp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="-10dp"
            android:text="@string/rutafix"
            android:textColor="@color/white"
            android:textSize="@dimen/text_size_splash"
            android:typeface="serif" />
    </LinearLayout>


    <View
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:layout_weight="2" />

    <!-- Créditos-->
    <TextView
        android:id="@+id/NombreDesarrollador"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginEnd="@dimen/margin_large"
        android:layout_marginBottom="@dimen/margin_large"
        android:text="@string/victor_moya"
        android:textColor="@color/white"
        android:textSize="@dimen/text_size_developer"
        android:textStyle="bold" />

</LinearLayout>