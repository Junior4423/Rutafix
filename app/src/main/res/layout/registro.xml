<?xml version="1.0" encoding="utf-8"?>
<!--
    PANTALLA DE REGISTRO
    Estructura basada en LinearLayouts para un control total del diseño vertical.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:orientation="vertical"
    tools:context=".Registro">

    <!-- CABECERA: Flecha de regreso y título principal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/margin_standard">

        <ImageView
            android:id="@+id/btnBackToLogin"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="@string/desc_boton_volver"
            android:focusable="true"
            android:padding="8dp"
            android:src="@drawable/abc_ic_ab_back_material"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/tituloRegistro"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/registro_titulo"
            android:textColor="@color/white"
            android:textSize="@dimen/text_size_title_secondary"
            android:textStyle="bold" />

        <View
            android:layout_width="48dp"
            android:layout_height="48dp" />
    </LinearLayout>

    <!-- FORMULARIO -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="@dimen/margin_large">

            <!-- Logo de la App -->
            <ImageView
                android:layout_width="@dimen/logo_login_header_width"
                android:layout_height="@dimen/logo_login_header_height"
                android:layout_marginBottom="@dimen/margin_large"
                android:contentDescription="@string/desc_logo_app"
                android:src="@drawable/logo" />

            <!-- Campos de entrada de datos -->
            <EditText
                android:id="@+id/editNombre"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_field_height"
                android:layout_marginBottom="12dp"
                android:background="@color/white"
                android:hint="@string/nombre"
                android:importantForAutofill="no"
                android:inputType="textPersonName"
                android:padding="@dimen/padding_small" />

            <EditText
                android:id="@+id/editApellido"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_field_height"
                android:layout_marginBottom="12dp"
                android:background="@color/white"
                android:hint="@string/apellido"
                android:importantForAutofill="no"
                android:inputType="textPersonName"
                android:padding="@dimen/padding_small" />

            <EditText
                android:id="@+id/editEmailRegistro"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_field_height"
                android:layout_marginBottom="12dp"
                android:background="@color/white"
                android:hint="@string/correo_electronico"
                android:importantForAutofill="no"
                android:inputType="textEmailAddress"
                android:padding="@dimen/padding_small" />

            <EditText
                android:id="@+id/editPasswordRegistro"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_field_height"
                android:layout_marginBottom="12dp"
                android:background="@color/white"
                android:hint="@string/contrase_a"
                android:importantForAutofill="no"
                android:inputType="textPassword"
                android:padding="@dimen/padding_small" />

            <EditText
                android:id="@+id/editConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_field_height"
                android:layout_marginBottom="16dp"
                android:background="@color/white"
                android:hint="@string/confirmar_contrase_a"
                android:importantForAutofill="no"
                android:inputType="textPassword"
                android:padding="@dimen/padding_small" />

            <!-- Aceptación de condiciones -->
            <CheckBox
                android:id="@+id/checkTerminos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:buttonTint="@color/green"
                android:text="@string/terminos_y_condiciones"
                android:textColor="@color/white" />

            <!-- Botón para finalizar registro -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/botonRegistrar"
                android:layout_width="@dimen/button_home_width"
                android:layout_height="@dimen/button_home_height"
                android:layout_marginBottom="32dp"
                android:background="@drawable/boton_redondo"
                android:text="@string/registrarse"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="@dimen/text_size_button" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>